{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "skipLibCheck": true
  },
  "include": ["App.js", "index.js", "src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx"]
}
