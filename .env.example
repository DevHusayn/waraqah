# Local dev
VITE_API_URL=http://localhost:5000/api

# Optional — error monitoring (Sentry). Prefer .env.local for your DSN (gitignored).
# VITE_SENTRY_DSN=https://yourPublicKey@o0.ingest.us.sentry.io/0

# Production (set in Vercel → Environment Variables, then redeploy):
# VITE_API_URL=https://api.mywaraqah.com/api
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sign in with Google / Apple (optional — buttons appear when set)
# Use the same Google OAuth client ID as GOOGLE_CLIENT_ID on the backend.
# VITE_GOOGLE_CLIENT_ID=
# VITE_APPLE_CLIENT_ID=
